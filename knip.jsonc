{
  "$schema": "https://unpkg.com/knip@6/schema.json",
  "ignoreDependencies": [
    // Kept as an explicit root dependency so JetBrains Vite integration and
    // Vite+ peer resolution both see the workspace-level Vite version.
    "vite",
  ],
  "ignoreFiles": ["apps/frontend/env.d.ts"],
  "ignoreIssues": {
    // The catalog intentionally pins shared tooling versions even when a
    // package consumes them indirectly through Vite+.
    "pnpm-workspace.yaml": ["catalog"],
  },
  "workspaces": {
    "apps/alienmark": {},
    "apps/frontend": {},
    "packages/alienmark": {
      "entry": ["test/**/*.ts"],
      "project": ["src/**/*.ts", "test/**/*.ts"],
    },
  },
}
