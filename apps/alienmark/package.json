{
  "name": "alienmark-service",
  "version": "0.1.0",
  "private": true,
  "description": "Internal HTTP service for AlienMark.",
  "type": "module",
  "main": "./dist/server.mjs",
  "scripts": {
    "build": "tsdown src/server.ts --format esm --dts false",
    "check": "tsc --noEmit",
    "dev": "tsx watch src/server.ts",
    "start": "node dist/server.mjs"
  },
  "dependencies": {
    "alienmark": "workspace:*",
    "fastify": "^5.6.2"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "tsdown": "^0.21.10",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3"
  }
}
