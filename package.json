{
  "name": "aliencommons",
  "private": true,
  "packageManager": "pnpm@11.8.0+sha512.c1f5e7c4cb241c8f174b743851d82f42b802324afc8b0f116b96adb15aa06664948dde36960a3ba1079ba5b4b29dd0140135b94b5b5f5263592249d68e555f26",
  "scripts": {
    "build": "turbo run build",
    "check": "turbo run check",
    "check:fix": "turbo run check:fix",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "lint:check": "turbo run lint:check",
    "lint:fix": "turbo run lint:fix",
    "knip": "knip --no-exit-code",
    "knip:strict": "knip",
    "style:check": "turbo run style:check",
    "style:fix": "turbo run style:fix",
    "alienmark-service:build": "turbo run build --filter=alienmark-service",
    "alienmark-service:check": "turbo run check --filter=alienmark-service",
    "alienmark-service:dev": "pnpm --filter alienmark-service dev",
    "alienmark-service:lint": "pnpm --filter alienmark-service lint:check",
    "alienmark-service:start": "pnpm --filter alienmark-service start",
    "alienmark-service:style": "pnpm --filter alienmark-service style:check",
    "alienmark-service:typecheck": "turbo run typecheck --filter=alienmark-service",
    "alienmark:build": "turbo run build --filter=alienmark",
    "alienmark:check": "turbo run check --filter=alienmark",
    "alienmark:dev": "pnpm --filter alienmark dev",
    "alienmark:lint": "pnpm --filter alienmark lint:check",
    "alienmark:style": "pnpm --filter alienmark style:check",
    "alienmark:test": "turbo run test --filter=alienmark",
    "alienmark:typecheck": "turbo run typecheck --filter=alienmark",
    "frontend:build": "turbo run build --filter=frontend",
    "frontend:check": "turbo run check --filter=frontend",
    "frontend:dev": "pnpm --filter frontend dev",
    "frontend:lint": "pnpm --filter frontend lint:check",
    "frontend:preview": "pnpm --filter frontend preview",
    "frontend:style": "pnpm --filter frontend style:check",
    "frontend:typecheck": "turbo run typecheck --filter=frontend",
    "prepare": "vp config"
  },
  "devDependencies": {
    "@types/node": "^26.0.0",
    "knip": "^6.17.1",
    "tsx": "^4.22.3",
    "turbo": "^2.9.18",
    "typescript": "^6.0.3",
    "vite": "catalog:",
    "vite-plus": "catalog:",
    "vue-tsc": "^3.3.5"
  }
}
