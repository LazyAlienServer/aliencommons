{
  "name": "alienmark-service",
  "version": "0.1.0",
  "private": true,
  "description": "Internal HTTP service for AlienMark.",
  "type": "module",
  "main": "./dist/server.mjs",
  "scripts": {
    "build": "vp pack src/server.ts --format esm --dts false",
    "check": "vp check",
    "check:fix": "vp check --fix",
    "dev": "tsx watch src/server.ts",
    "fmt:check": "vp fmt --check",
    "fmt:fix": "vp fmt",
    "lint:check": "vp lint",
    "lint:fix": "vp lint --fix",
    "typecheck": "tsc --noEmit",
    "start": "node dist/server.mjs"
  },
  "dependencies": {
    "alienmark": "workspace:*",
    "fastify": "^5.9.0"
  }
}
